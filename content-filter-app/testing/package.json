{
  "name": "content-filter-testing",
  "version": "1.0.0",
  "description": "Comprehensive testing suite for Content Filter ecosystem",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "jest --config jest.unit.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "npm run test:e2e:browser && npm run test:e2e:desktop && npm run test:e2e:mobile",
    "test:e2e:browser": "jest --config jest.e2e.browser.config.js",
    "test:e2e:desktop": "jest --config jest.e2e.desktop.config.js",
    "test:e2e:mobile": "npm run test:e2e:android && npm run test:e2e:ios",
    "test:e2e:android": "jest --config jest.e2e.android.config.js",
    "test:e2e:ios": "jest --config jest.e2e.ios.config.js",
    "test:performance": "artillery run performance-tests.yml",
    "test:security": "npm run test:security:scan && npm run test:security:audit",
    "test:security:scan": "snyk test",
    "test:security:audit": "npm audit",
    "test:coverage": "jest --coverage --config jest.coverage.config.js",
    "test:watch": "jest --watch --config jest.watch.config.js",
    "test:ci": "npm run test:all && npm run test:coverage && npm run test:security",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "build": "npm run build:browser && npm run build:desktop && npm run build:mobile",
    "build:browser": "cd ../browser-extension && npm run build",
    "build:desktop": "cd ../platforms/desktop && npm run build",
    "build:mobile": "npm run build:android && npm run build:ios",
    "build:android": "cd ../platforms/android && ./gradlew assembleRelease",
    "build:ios": "cd ../platforms/ios && xcodebuild -project ContentFilter.xcodeproj -configuration Release",
    "deploy": "npm run deploy:browser && npm run deploy:desktop && npm run deploy:mobile",
    "deploy:browser": "cd ../browser-extension && npm run deploy",
    "deploy:desktop": "cd ../platforms/desktop && npm run deploy",
    "deploy:mobile": "npm run deploy:android && npm run deploy:ios",
    "deploy:android": "cd ../platforms/android && ./gradlew publishApkRelease",
    "deploy:ios": "cd ../platforms/ios && xcodebuild -project ContentFilter.xcodeproj -configuration Release archive",
    "monitor": "npm run monitor:performance && npm run monitor:health",
    "monitor:performance": "node scripts/monitor-performance.js",
    "monitor:health": "node scripts/monitor-health.js",
    "clean": "npm run clean:cache && npm run clean:builds && npm run clean:logs",
    "clean:cache": "rm -rf node_modules/.cache",
    "clean:builds": "rm -rf dist build output",
    "clean:logs": "rm -rf logs *.log"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "jest-environment-node": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-puppeteer": "^8.0.0",
    "puppeteer": "^20.0.0",
    "supertest": "^6.3.0",
    "artillery": "^2.0.0",
    "eslint": "^8.40.0",
    "prettier": "^2.8.0",
    "snyk": "^1.1290.0",
    "electron-mocha": "^11.1.0",
    "spectron": "^19.0.0",
    "appium": "^2.0.0",
    "webdriverio": "^8.0.0",
    "cypress": "^12.0.0",
    "playwright": "^1.30.0",
    "nyc": "^15.1.0",
    "istanbul-lib-coverage": "^3.2.0",
    "jest-junit": "^16.0.0",
    "jest-stare": "^2.5.0",
    "allure-jest": "^2.9.0",
    "jest-performance": "^1.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "sqlite3": "^5.1.6",
    "systeminformation": "^5.18.0",
    "node-notifier": "^10.0.1",
    "chalk": "^5.2.0",
    "figlet": "^1.6.0",
    "inquirer": "^9.2.0",
    "commander": "^10.0.0",
    "ora": "^6.3.0",
    "progress": "^2.0.3",
    "winston": "^3.9.0",
    "dotenv": "^16.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "helmet": "^6.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/*.config.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json-summary"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.{js,ts}",
      "**/*.{test,spec}.{js,ts}"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testTimeout": 30000,
    "verbose": true,
    "clearMocks": true,
    "resetMocks": true,
    "restoreMocks": true
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/content-filter"
  },
  "keywords": [
    "testing",
    "content-filter",
    "automation",
    "quality-assurance",
    "cross-platform"
  ],
  "author": "Content Filter Team",
  "license": "MIT"
}