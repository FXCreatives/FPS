{
  "name": "content-filter-desktop",
  "version": "1.0.0",
  "description": "Cross-platform desktop content filtering application",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_IS_DEV=true electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "npm run build",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "content-filter",
    "desktop",
    "electron",
    "security",
    "parental-control"
  ],
  "author": "Content Filter Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "sqlite3": "^5.1.6",
    "systeminformation": "^5.18.0",
    "active-win": "^8.1.0",
    "node-notifier": "^10.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "dns-lookup": "^0.0.2"
  },
  "build": {
    "appId": "com.contentfilter.desktop",
    "productName": "Content Filter Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*",
      "!**/*.md",
      "!**/.git*",
      "!**/.DS_Store"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icons/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}