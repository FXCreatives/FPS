{
  "manifest_version": 3,
  "name": "Content Filtering Extension",
  "version": "1.0.0",
  "description": "Advanced content filtering and blocking extension",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "offscreen",
    "webNavigation"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Content Filtering Extension",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },

  "content_scripts": [
    {
      "matches": ["*://*.pornhub.com/*", "*://*.xvideos.com/*", "*://*.xhamster.com/*", "*://*.youporn.com/*", "*://*.redtube.com/*", "*://*.bet365.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js", "blocked.css", "options.html", "options.js", "popup.html", "popup.js"],
      "matches": ["<all_urls>"]
    }
  ]
}